}

void buyerMenu() {
    header("BUYER PANEL");
    if (buyerCount == 0) { cout << "  No buyers registered!\n"; return; }

    cout << "  Select Buyer:\n";
    for (int i = 0; i < buyerCount; i++)
        cout << "    " << i << ". " << buyers[i].getUsername() << "\n";

    int bi; cout << "  Buyer index: "; cin >> bi; cin.ignore();
    if (bi < 0 || bi >= buyerCount) { cout << "  Invalid.\n"; return; }

    header("BUYER PANEL - " + buyers[bi].getUsername());
    cout << "  1. Save Listing to Favorites\n";
    cout << "  2. View My Favorites\n";
    cout << "  3. Send Message to Seller\n";
    cout << "  4. View Sent Messages\n";
    cout << "  5. View My Profile\n";
    cout << "  Choice: ";

    int ch; cin >> ch; cin.ignore();

    if (ch == 1) {
        showAllListings();
        int li; cout << "  Listing index to save: "; cin >> li; cin.ignore();
        if (li >= 0 && li < lstCount && listings[li])
            buyers[bi].addToFavs(listings[li]);

    } else if (ch == 2) {
        buyers[bi].showFavs();

    } else if (ch == 3) {
        cout << "  Seller User IDs:\n";
        for (int i = 0; i < sellerCount; i++)
            cout << "    " << sellers[i].getUID()
                 << " - " << sellers[i].getUsername() << "\n";

        int rid; cout << "  Receiver User ID: "; cin >> rid; cin.ignore();
        string msg; cout << "  Message         : "; getline(cin, msg);
        buyers[bi].sendMsg(rid, msg, "2026-03-01");

    } else if (ch == 4) {
        buyers[bi].showSentMsgs();

    } else if (ch == 5) {
        buyers[bi].showProfile();
    }
    pause();
}

void adminMenu() {
    header("ADMIN PANEL");

    if (adminCount == 0) {
        admins[adminCount++] = Admin("superadmin", "admin@pakwheels.pk",
                                     "0300-0000000", "SuperAdmin", "IT");
        cout << "  Default admin created  ->  username: superadmin\n";
    }

    cout << "  Admin username: "; string un; cin.ignore(); getline(cin, un);
    int ai = -1;
    for (int i = 0; i < adminCount; i++)
        if (admins[i].getUsername() == un) { ai = i; break; }

    if (ai == -1) { cout << "  Admin not found!\n"; return; }

    header("ADMIN PANEL - " + admins[ai].getUsername());
    cout << "  1. Approve Listing\n";
    cout << "  2. Remove Listing\n";
    cout << "  3. View All Listings (detail)\n";
    cout << "  4. Verify a Seller\n";
    cout << "  5. System Statistics\n";
    cout << "  6. Compare Two Listing Prices  [friend func demo]\n";
    cout << "  7. Generate Seller Report      [IReportable demo]\n";
    cout << "  Choice: ";

    int ch; cin >> ch; cin.ignore();

    if (ch == 1) {
        showAllListings();
        int li; cout << "  Listing index to approve: "; cin >> li; cin.ignore();
        if (li >= 0 && li < lstCount && listings[li])
            admins[ai].okayListing(*listings[li]);

    } else if (ch == 2) {
        showAllListings();
        int li; cout << "  Listing index to remove: "; cin >> li; cin.ignore();
        if (li >= 0 && li < lstCount && listings[li])
            admins[ai].pullListing(*listings[li]);

    } else if (ch == 3) {
        header("DETAILED LISTING VIEW");
        for (int i = 0; i < lstCount; i++)
            if (listings[i] && listings[i]->isActiveStatus())
                listings[i]->printListing();

    } else if (ch == 4) {
        cout << "  Sellers:\n";
        for (int i = 0; i < sellerCount; i++)
            cout << "    " << i << ". " << sellers[i].getUsername() << "\n";
        int si; cout << "  Seller index: "; cin >> si; cin.ignore();
        if (si >= 0 && si < sellerCount) sellers[si].verify();

    } else if (ch == 5) {
        header("SYSTEM STATISTICS");
        cout << "  Total Users Created  : " << User::getUserCount()       << "\n";
        cout << "  Total Vehicles Live  : " << Vehicle::getVehicleCount() << "\n";
        cout << "  Total Listings Live  : " << Listing::getListCnt()      << "\n";
        cout << "  Total Messages Live  : " << Message::getMsgCount()     << "\n";
        cout << "  Registered Sellers   : " << sellerCount                << "\n";
        cout << "  Registered Buyers    : " << buyerCount                 << "\n";
        cout << "  Registered Admins    : " << adminCount                 << "\n";
        cout << "  Next Listing ID      : " << Listing::getNextLID()      << "\n";
        admins[ai].showAdminInfo();
        admins[ai].genReport();   // IReportable

    } else if (ch == 6) {
        if (lstCount < 2) { cout << "  Need at least 2 listings.\n"; }
        else {
            int a, b;
            cout << "  First listing index : "; cin >> a; cin.ignore();
            cout << "  Second listing index: "; cin >> b; cin.ignore();
            if (a >= 0 && a < lstCount && b >= 0 && b < lstCount && listings[a] && listings[b])
                comparePrices(*listings[a], *listings[b]);
        }

    } else if (ch == 7) {
        cout << "  Sellers:\n";
        for (int i = 0; i < sellerCount; i++)
            cout << "    " << i << ". " << sellers[i].getUsername() << "\n";
        int si; cout << "  Seller index: "; cin >> si; cin.ignore();
        if (si >= 0 && si < sellerCount) {
            IReportable* rpt = &sellers[si];   // upcast to interface
            rpt->genReport();
        }
    }
    pause();
}



