//  ABSTRACT CLASS 1 : ISearchable
//  Pure virtual interface -- any class that wants to be
//  searchable inside the marketplace must implement these two.
//  Listing inherits this so we can search listings by keyword.

class ISearchable {
public:
    virtual bool   matchesQuery(const string& kw)  const = 0;
    virtual string getSearchKey()                  const = 0;
    virtual ~ISearchable() {}
};



//  ABSTRACT CLASS 2 : IReportable
//  Any user role that can produce a summary report implements
//  this. Seller and Admin both inherit it below.

class IReportable {
public:
    virtual void   genReport()    const = 0;
    virtual string getSummaryTxt() const = 0;
    virtual ~IReportable() {}
};



//  ABSTRACT CLASS 3 : IPriceable
//  Anything that has a price and can be discounted implements
//  this. Listing inherits it -- keeps pricing logic separate.

class IPriceable {
public:
    virtual double  getBasePrice()          const = 0;
    virtual double  getDiscountedPrice(int pct) const = 0;
    virtual ~IPriceable() {}
};



//  ABSTRACT CLASS 4 : IVerifiable
//  Seller accounts can be verified; this interface enforces
//  a standard way to check and set that state.

class IVerifiable {
public:
    virtual bool   isVerified()  const = 0;
    virtual void   doVerify()          = 0;
    virtual ~IVerifiable() {}
};



//  Engine

class Engine {
private:
    string engKind;
    float  ccSize;
    int    horsePwr;
    int    torque;
    bool   hasTurbo;

public:
    Engine()
        : engKind("Unknown"), ccSize(0.0f),
          horsePwr(0), torque(0), hasTurbo(false) {}

    Engine(string type, float disp, int hp, int tq, bool turbo)
        : engKind(type), ccSize(disp),
          horsePwr(hp), torque(tq), hasTurbo(turbo) {}

    Engine(const Engine& e)
        : engKind(e.engKind), ccSize(e.ccSize),
          horsePwr(e.horsePwr), torque(e.torque),
          hasTurbo(e.hasTurbo) {}

    Engine& operator=(const Engine& e) {
        if (this != &e) {
            engKind  = e.engKind;
            ccSize   = e.ccSize;
            horsePwr = e.horsePwr;
            torque   = e.torque;
            hasTurbo = e.hasTurbo;
        }
        return *this;
    }

    //  OPERATOR OVERLOAD 1 : == 
    // Compares two engines by type + CC size. Used when a buyer
    // wants to find listings with an identical engine spec.
    
    bool operator==(const Engine& e) const {
        return (engKind == e.engKind && (int)ccSize == (int)e.ccSize);
    }

    //  OPERATOR OVERLOAD 2 : + 
    // Merges two engine specs into one combined engine object.
    // Useful for twin-engine performance calc / display.
    Engine operator+(const Engine& e) const {
        Engine merged;
        merged.engKind  = engKind + "+" + e.engKind;
        merged.ccSize   = ccSize  + e.ccSize;
        merged.horsePwr = horsePwr + e.horsePwr;
        merged.torque   = torque   + e.torque;
        merged.hasTurbo = hasTurbo || e.hasTurbo;
        return merged;
    }

    void printEngInfo() const {
        cout << "    Engine   : " << engKind
             << " | " << ccSize << " CC"
             << " | " << horsePwr << " HP"
             << " | " << torque   << " Nm";
        if (hasTurbo) cout << " | TURBO";
        cout << "\n";
    }

    bool isHighPower() const { return horsePwr > 200; }

    void boostEngine(int extraHP) {
        horsePwr += extraHP;
        cout << "    [Engine Upgraded] New HP: " << horsePwr << "\n";
    }

    string getShortDesc() const {
        ostringstream oss;
        oss << engKind << " " << (int)ccSize << "CC "
            << horsePwr << "HP" << (hasTurbo ? " T" : "");
        return oss.str();
    }

    string getEngineType() const { return engKind;  }
    float  getCCSize()     const { return ccSize;   }
    int    getHorsePwr()   const { return horsePwr; }
    int    getTorque()     const { return torque;   }
    bool   isTurbo()       const { return hasTurbo; }

    void setEngineType(string t) { engKind   = t;  }
    void setCCSize    (float  d) { ccSize    = d;  }
    void setHorsePwr  (int   hp) { horsePwr  = hp; }
    void setTorque    (int    t) { torque    = t;  }
    void setTurboFlag (bool   b) { hasTurbo  = b;  }


    //  FRIEND FUNCTION 1 
    // printEngineSecret needs direct access to private engKind
    // and horsePwr without going through getters, because this
    // is a diagnostic dump used only in specific admin contexts.
    friend void printEngineSecret(const Engine& e);
};

// friend function defined outside the class
void printEngineSecret(const Engine& e) {
    cout << "  [DIAG] Engine internals -> kind: " << e.engKind
         << "  raw HP: "  << e.horsePwr
         << "  turbo: "   << (e.hasTurbo ? "yes" : "no") << "\n";
}



//  Vehicle  (Abstract class -- already was one)

class Vehicle {
private:
    string brand;
    string model;
    int    year;
    float  mileage;
    string color;
    Engine engine;

public:
    static int vehicleCount;

    Vehicle()
        : brand("Unknown"), model("Unknown"), year(2000),
          mileage(0.0f), color("White") {
        vehicleCount++;
    }

    Vehicle(string b, string m, int y, float mil, string c, Engine eng)
        : brand(b), model(m), year(y), mileage(mil), color(c), engine(eng) {
        vehicleCount++;
    }

    Vehicle(const Vehicle& v)
        : brand(v.brand), model(v.model), year(v.year),
          mileage(v.mileage), color(v.color), engine(v.engine) {
        vehicleCount++;
    }

    virtual ~Vehicle() { vehicleCount--; }

    // pure virtual -- every derived vehicle must implement these
    virtual void   display()        const = 0;
    virtual string getVehicleType() const = 0;

    //  OPERATOR OVERLOAD 3 : == 
    // Two vehicles are "equal" if same brand + model + year.
    // Useful when checking for duplicate listings.
    bool operator==(const Vehicle& v) const {
        return (brand == v.brand && model == v.model && year == v.year);
    }

    string        getBrand()   const { return brand;   }
    string        getModel()   const { return model;   }
    int           getYear()    const { return year;    }
    float         getMileage() const { return mileage; }
    string        getColor()   const { return color;   }
    const Engine& getEngine()  const { return engine;  }

    void showBasicInfo() const {
        cout << brand << " " << model
             << " (" << year << ") | "
             << mileage << " km | " << color << "\n";
    }

    bool isRecentMake() const { return year >= 2024;       }
    bool hasLowKM()     const { return mileage < 50000.0f; }

    void setBrand  (string b) { brand   = b; }
    void setModel  (string m) { model   = m; }
    void setYear   (int    y) { year    = y; }
    void setMileage(float  m) { mileage = m; }
    void setColor  (string c) { color   = c; }
    void setEngine (Engine e) { engine  = e; }

    static int getVehicleCount() { return vehicleCount; }
};

int Vehicle::vehicleCount = 0;



