//  User  (Abstract)

class User {
private:
    int    uid;
    string username;
    string email;
    string pwdHash;
    string phoneNum;
    bool   isActive;

    static const string PLATFORM;

public:
    static int userCount;
    static int nextUID;

    User()
        : uid(nextUID++), username("Guest"), email(""),
          pwdHash(""), phoneNum(""), isActive(true) {
        userCount++;
    }

    User(string uname, string mail, string phone)
        : uid(nextUID++), username(uname), email(mail),
          pwdHash("hash_" + uname), phoneNum(phone), isActive(true) {
        userCount++;
    }

    User(const User& u)
        : uid(nextUID++), username(u.username + "_copy"),
          email(u.email), pwdHash(u.pwdHash),
          phoneNum(u.phoneNum), isActive(u.isActive) {
        userCount++;
    }

    User& operator=(const User& u) {
        if (this != &u) {
            username = u.username;
            email    = u.email;
            pwdHash  = u.pwdHash;
            phoneNum = u.phoneNum;
            isActive = u.isActive;
        }
        return *this;
    }

    //  OPERATOR OVERLOAD 4 : == 
    // Two user accounts are equal if they share the same UID.
    // Handy when checking for duplicate registrations.
    bool operator==(const User& u) const {
        return uid == u.uid;
    }

    virtual ~User() { userCount--; }

    // pure virtual -- every role must say what it is
    virtual string getRole() const = 0;

    virtual void showProfile() const {
        cout << "    User ID  : " << uid
             << "  |  Username: " << username << "\n";
        cout << "    Email    : " << email
             << "  |  Phone   : " << phoneNum << "\n";
        cout << "    Status   : " << (isActive ? "Active" : "Inactive")
             << "  |  Platform: " << PLATFORM << "\n";
    }

    static int getUserCount() { return userCount; }

    bool checkLogin(const string& uname, const string& /*pass*/) const {
        return (username == uname && pwdHash == "hash_" + uname);
    }

    void disableAccount() {
        isActive = false;
        cout << "    Account [" << username << "] deactivated.\n";
    }

    void changeEmail(const string& newEmail) { email = newEmail; }

    int    getUID()         const { return uid;      }
    string getUsername()    const { return username; }
    string getEmail()       const { return email;    }
    string getPhone()       const { return phoneNum; }
    bool   isActiveStatus() const { return isActive; }

    void setUsername(string u) { username = u; }
    void setEmail   (string e) { email    = e; }
    void setPhone   (string p) { phoneNum = p; }
    void setActive  (bool   a) { isActive = a; }


    //  FRIEND FUNCTION 2 
    // transferBudget needs to read and write Buyer::budget directly.
    // Declared here in User so the friendship applies to the derived
    // Buyer class members when we forward-declare below.
    // (actual definition is after Buyer class)
    friend void transferBudget(class Buyer& giver, class Buyer& recvr, float amt);
};

int User::userCount = 0;
int User::nextUID   = 1001;
const string User::PLATFORM = "PakWheels-Clone";



//  Message

class Message {
private:
    int    messageID;
    int    senderID;
    int    receiverID;
    string content;
    string timestamp;
    bool   isRead;

    static const int MAX_CHAR_LIMIT = 500;
    static int msgCount;
    static int nextMID;

public:
    Message()
        : messageID(nextMID++), senderID(0), receiverID(0),
          content(""), timestamp("N/A"), isRead(false) {
        msgCount++;
    }

    Message(int sid, int rid, const string& msg, const string& ts)
        : messageID(nextMID++), senderID(sid), receiverID(rid),
          content(msg.length() > 500 ? msg.substr(0, 500) : msg),
          timestamp(ts), isRead(false) {
        msgCount++;
    }

    Message(const Message& m)
        : messageID(nextMID++), senderID(m.senderID),
          receiverID(m.receiverID), content(m.content),
          timestamp(m.timestamp), isRead(m.isRead) {
        msgCount++;
    }

    Message& operator=(const Message& m) {
        if (this != &m) {
            senderID   = m.senderID;
            receiverID = m.receiverID;
            content    = m.content;
            timestamp  = m.timestamp;
            isRead     = m.isRead;
        }
        return *this;
    }

    ~Message() { msgCount--; }

    void printMsg() const {
        cout << "    [MSG #"  << messageID
             << "] From: "   << senderID
             << "  ->  To: " << receiverID << "\n";
        cout << "    Content : " << content   << "\n";
        cout << "    Time    : " << timestamp
             << "  |  Read: " << (isRead ? "Yes" : "No") << "\n";
    }

    void flagRead()       { isRead = true;          }
    bool isEmpty()  const { return content.empty();  }

    string getMsgPreview() const {
        return content.length() > 40 ? content.substr(0, 40) + "..." : content;
    }

    static int getMsgCount() { return msgCount; }

    int    getMsgID()    const { return messageID;  }
    int    getSender()   const { return senderID;   }
    int    getReceiver() const { return receiverID; }
    string getContent()  const { return content;    }
    bool   wasRead()     const { return isRead;     }

    void setContent(const string& c) {
        content = (c.length() > 500) ? c.substr(0, 500) : c;
    }
    void markRead(bool r) { isRead = r; }
};

int Message::msgCount = 0;
int Message::nextMID  = 5001;



//  Listing  (also implements ISearchable and IPriceable)

class Listing : public ISearchable, public IPriceable {
private:
    int      listingID;
    Vehicle* vehicle;
    int      sellerID;
    double   price;
    string   location;
    bool     isApproved;
    bool     isActive;

    static const string CURRENCY;
    static int listCnt;
    static int nextLID;

public:
    Listing()
        : listingID(nextLID++), vehicle(NULL), sellerID(0),
          price(0.0), location("Unknown"), isApproved(false), isActive(true) {
        listCnt++;
    }

    Listing(Vehicle* v, int sid, double p, const string& loc)
        : listingID(nextLID++), vehicle(v), sellerID(sid),
          price(p), location(loc), isApproved(false), isActive(true) {
        listCnt++;
    }

    Listing(const Listing& l)
        : listingID(nextLID++), vehicle(NULL),
          sellerID(l.sellerID), price(l.price), location(l.location),
          isApproved(l.isApproved), isActive(l.isActive) {
        listCnt++;
    }

    ~Listing() {
        delete vehicle;
        vehicle = NULL;
        listCnt--;
    }

    //  ISearchable implementation 
    // matchesQuery checks if the keyword appears in brand/model/location.
    bool matchesQuery(const string& kw) const override {
        if (!vehicle) return false;
        return (vehicle->getBrand().find(kw)  != string::npos ||
                vehicle->getModel().find(kw)  != string::npos ||
                location.find(kw)             != string::npos);
    }

    string getSearchKey() const override {
        if (!vehicle) return location;
        return vehicle->getBrand() + " " + vehicle->getModel();
    }

    //  IPriceable implementation 
    double getBasePrice() const override { return price; }

    double getDiscountedPrice(int pct) const override {
        if (pct < 0 || pct > 100) return price;
        return price - (price * pct / 100.0);
    }

    //  OPERATOR OVERLOAD 5 : < 
    // Compare two listings by price (cheaper = "less than").
    // Useful for sorting / finding the best deal.
    bool operator<(const Listing& l) const {
        return price < l.price;
    }

    void printListing() const {
        cout << "\n  +--- LISTING #" << listingID << " -+\n";
        cout << "  |  Price    : " << CURRENCY << " "
             << fixed << setprecision(0) << price
             << "  |  Location : " << location << "\n";
        cout << "  |  Approved : " << (isApproved ? "Yes" : "Pending")
             << "   |  Active   : " << (isActive ? "Yes" : "No") << "\n";
        cout << "  +---+\n";
        if (vehicle) vehicle->display();
    }

    void printCompact() const {
        if (!vehicle) return;
        cout << "  [#" << setw(4) << listingID << "] "
             << vehicle->getBrand() << " " << vehicle->getModel()
             << " (" << vehicle->getYear() << ")"
             << "  -  " << CURRENCY << " " << price
             << "  |  " << location
             << "  |  " << (isApproved ? "Approved" : "Pending") << "\n";
    }

    bool fitsBrand  (const string& b)          const { return vehicle && vehicle->getBrand()   == b; }
    bool fitsModel  (const string& m)          const { return vehicle && vehicle->getModel()   == m; }
    bool fitsPrice  (double minP, double maxP) const { return price >= minP && price <= maxP;         }
    bool fitsYear   (int y)                    const { return vehicle && vehicle->getYear()    == y;  }
    bool fitsMileage(float maxMiles)           const { return vehicle && vehicle->getMileage() <= maxMiles; }

    static int getListCnt() { return listCnt; }
    static int getNextLID() { return nextLID; }

    int      getLID()           const { return listingID;  }
    Vehicle* getVehicle()       const { return vehicle;    }
    int      getSellerID()      const { return sellerID;   }
    double   getPrice()         const { return price;      }
    string   getLocation()      const { return location;   }
    bool     isApprovedStatus() const { return isApproved; }
    bool     isActiveStatus()   const { return isActive;   }

    void setPrice   (double p) { price      = p; }
    void setLocation(string l) { location   = l; }
    void setApproved(bool   a) { isApproved = a; }
    void setActive  (bool   a) { isActive   = a; }


    //  FRIEND FUNCTION 3 
    // comparePrices needs direct access to the private price field
    // of both listings without going through getters, to do a fast
    // raw comparison (e.g. for an admin audit report).
    friend void comparePrices(const Listing& a, const Listing& b);
};

int Listing::listCnt = 0;
int Listing::nextLID = 3001;
const string Listing::CURRENCY = "PKR";

void comparePrices(const Listing& a, const Listing& b) {
    cout << "  [PRICE COMPARE] Listing #" << a.listingID
         << " (PKR " << a.price << ")  vs  Listing #"
         << b.listingID << " (PKR " << b.price << ")  ->  ";

    if (a.price < b.price)
        cout << "Listing #" << a.listingID << " is cheaper.\n";
    else if (b.price < a.price)
        cout << "Listing #" << b.listingID << " is cheaper.\n";
    else
        cout << "Same price.\n";
}



//  Admin  (inherits User + IReportable)

class Admin : public User, public IReportable {
private:
    string adminRank;
    string department;
    int    managedListings;
    bool   banPermission;
    int    yrsActive;

public:
    Admin()
        : User(), adminRank("Moderator"), department("Operations"),
          managedListings(0), banPermission(false), yrsActive(0) {}

    Admin(string uname, string email, string phone,
          string level, string dept)
        : User(uname, email, phone), adminRank(level), department(dept),
          managedListings(0), banPermission(level == "SuperAdmin"),
          yrsActive(0) {}

    Admin(const Admin& a)
        : User(a), adminRank(a.adminRank), department(a.department),
          managedListings(a.managedListings), banPermission(a.banPermission),
          yrsActive(a.yrsActive) {}

    Admin& operator=(const Admin& a) {
        if (this != &a) {
            User::operator=(a);
            adminRank       = a.adminRank;
            department      = a.department;
            managedListings = a.managedListings;
