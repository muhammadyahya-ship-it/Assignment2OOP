             << "  |  Rating  : " << fixed << setprecision(1) << rating << "/5\n";
        cout << "    Verified : " << (verified ? "Yes" : "No")
             << "  |  Sales   : " << salesDone << "\n";
    }

    //  IReportable implementation 
    void genReport() const override {
        cout << "\n  === SELLER REPORT ===\n";
        cout << "  Seller     : " << getUsername() << " (" << bizName << ")\n";
        cout << "  Rating     : " << fixed << setprecision(1) << rating << "/5\n";
        cout << "  Sales Done : " << salesDone << "\n";
        cout << "  Verified   : " << (verified ? "Yes" : "No") << "\n";
        cout << "  Listings   : " << lstCount << "\n";
    }

    string getSummaryTxt() const override {
        return "Seller[" + getUsername() + "] biz=" + bizName +
               " rating=" + to_string((int)rating) + "/5";
    }

    //  IVerifiable implementation 
    bool isVerified() const override { return verified; }
    void doVerify()         override {
        verified = true;
        cout << "    Seller [" << getUsername() << "] verified!\n";
    }

    bool addLstRef(Listing* listing) {
        if (lstCount < MAX_SELLER_LISTINGS) {
            myListings[lstCount++] = listing;
            return true;
        }
        cout << "    Seller listing capacity full.\n";
        return false;
    }

    void showMyListings() const {
        cout << "\n  === Listings by " << bizName << " ===\n";
        bool any = false;
        for (int i = 0; i < lstCount; i++) {
            if (myListings[i] && myListings[i]->isActiveStatus()) {
                myListings[i]->printCompact();
                any = true;
            }
        }
        if (!any) cout << "  No active listings.\n";
    }

    void refreshRating(float newRating) {
        if (newRating >= 1.0f && newRating <= 5.0f)
            rating = (rating == 0.0f) ? newRating : (rating + newRating) / 2.0f;
    }

    void logSale() { salesDone++; }

    // kept for backward compatibility (calls doVerify internally)
    void verify() { doVerify(); }

    string   getBizName()    const { return bizName;  }
    float    getRating()     const { return rating;   }
    bool     checkVerified() const { return verified; }
    int      getLstCount()   const { return lstCount; }
    Listing* getListing(int i) const {
        return (i >= 0 && i < lstCount) ? myListings[i] : NULL;
    }

    void setBizName  (string b) { bizName  = b; }
    void markVerified(bool   v) { verified = v; }

    // friend declaration so isCompatible can read private rating
    friend bool isCompatible(const Seller& s, const Buyer& b);
};



//  Buyer  (inherits User)

class Buyer : public User {
private:
    float    budget;
    string   favBrand;
    Listing* favorites[MAX_FAVORITES];
    int      favCount;
    Message  sentMessages[50];
    int      msgCount;

public:
    Buyer()
        : User(), budget(0.0f), favBrand("Any"),
          favCount(0), msgCount(0) {
        for (int i = 0; i < MAX_FAVORITES; i++) favorites[i] = NULL;
    }

    Buyer(string uname, string email, string phone, float budg, string brand)
        : User(uname, email, phone), budget(budg), favBrand(brand),
          favCount(0), msgCount(0) {
        for (int i = 0; i < MAX_FAVORITES; i++) favorites[i] = NULL;
    }

    Buyer(const Buyer& b)
        : User(b), budget(b.budget), favBrand(b.favBrand),
          favCount(b.favCount), msgCount(b.msgCount) {
        for (int i = 0; i < MAX_FAVORITES; i++) favorites[i]    = b.favorites[i];
        for (int i = 0; i < msgCount;      i++) sentMessages[i] = b.sentMessages[i];
    }

    Buyer& operator=(const Buyer& b) {
        if (this != &b) {
            User::operator=(b);
            budget   = b.budget;
            favBrand = b.favBrand;
            favCount = b.favCount;
            msgCount = b.msgCount;
            for (int i = 0; i < MAX_FAVORITES; i++) favorites[i]    = b.favorites[i];
            for (int i = 0; i < msgCount;      i++) sentMessages[i] = b.sentMessages[i];
        }
        return *this;
    }

    string getRole() const override { return "Buyer"; }

    void showProfile() const override {
        User::showProfile();
        cout << "    Role     : Buyer"
             << "  |  Budget   : PKR " << fixed << setprecision(0) << budget
             << "  |  Pref Brand: " << favBrand << "\n";
        cout << "    Favorites: " << favCount
             << "  |  Messages Sent: " << msgCount << "\n";
    }

    bool addToFavs(Listing* listing) {
        if (favCount >= MAX_FAVORITES) {
            cout << "    Favorites list full.\n";
            return false;
        }
        for (int i = 0; i < favCount; i++)
            if (favorites[i] == listing) {
                cout << "    Already in favorites.\n";
                return false;
            }
        favorites[favCount++] = listing;
        cout << "    Listing #" << listing->getLID() << " saved to favorites!\n";
        return true;
    }

    void showFavs() const {
        cout << "\n  === " << getUsername() << "'s Favorites (" << favCount << ") ===\n";
        if (favCount == 0) { cout << "  No favorites saved.\n"; return; }
        for (int i = 0; i < favCount; i++)
            if (favorites[i]) favorites[i]->printCompact();
    }

    bool sendMsg(int receiverID, const string& content, const string& ts) {
        if (msgCount >= 50) { cout << "    Message inbox full.\n"; return false; }
        sentMessages[msgCount++] = Message(getUID(), receiverID, content, ts);
        cout << "    Message sent to User #" << receiverID << "\n";
        return true;
    }

    void showSentMsgs() const {
        cout << "\n  === Messages from " << getUsername() << " ===\n";
        if (msgCount == 0) { cout << "  No messages sent.\n"; return; }
        for (int i = 0; i < msgCount; i++) sentMessages[i].printMsg();
    }

    bool withinBudget(double p) const { return budget >= p; }

    float  getBudget()   const { return budget;   }
    string getFavBrand() const { return favBrand; }
    int    getFavCount() const { return favCount; }
    int    getMsgCount() const { return msgCount; }

    void setBudget  (float  b) { budget   = b; }
    void setFavBrand(string p) { favBrand = p; }


    //  FRIEND FUNCTION 4 
    // isCompatible checks whether a seller's rating is good enough
    // for a buyer's budget tier. It needs raw access to Seller::rating
    // and Buyer::budget which are both private. Declared friend in
    // both classes (Seller above already has it through User friend chain).
    friend bool isCompatible(const Seller& s, const Buyer& b);

    // transferBudget friend declared in User, but needs Buyer::budget
    // so re-declared here for access
    friend void transferBudget(Buyer& giver, Buyer& recvr, float amt);
};


// friend function bodies for Buyer-related friends
bool isCompatible(const Seller& s, const Buyer& b) {
    // a seller with rating >= 3.5 is compatible with any budget > 500k
    bool ratingOk = (s.rating >= 3.5f);
    bool budgetOk = (b.budget > 500000.0f);
    cout << "  [COMPAT CHECK] Seller rating=" << s.rating
         << "  Buyer budget=PKR " << b.budget
         << "  -> " << ((ratingOk && budgetOk) ? "Compatible" : "Not compatible") << "\n";
    return ratingOk && budgetOk;
}

void transferBudget(Buyer& giver, Buyer& recvr, float amt) {
    if (giver.budget < amt) {
        cout << "  [TRANSFER] Insufficient budget in " << giver.getUsername() << "\n";
        return;
    }
    giver.budget -= amt;
    recvr.budget += amt;
    cout << "  [TRANSFER] PKR " << amt << " moved from "
         << giver.getUsername() << " to " << recvr.getUsername() << "\n";
}



